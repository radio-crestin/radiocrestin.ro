# Hashed static assets — immutable, cache forever (content-hash in filename)
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

# Fonts — cache for 1 year
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Images — cache for 1 week
/images/*
  Cache-Control: public, max-age=604800

/icons/*
  Cache-Control: public, max-age=604800

# Everything else (HTML pages, data JSON) — never cache
# This ensures browsers always get the latest HTML after deployments,
# preventing 503s from stale HTML referencing old chunk hashes.
/*
  Cache-Control: public, max-age=0, must-revalidate
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
