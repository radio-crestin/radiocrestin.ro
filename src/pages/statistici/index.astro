---
import BaseLayout from "../../layouts/BaseLayout.astro";
import StatisticiApp from "@/components/StatisticiApp";
import { getOptimizedStations } from "@/utils/getOptimizedStations";
import { SEO_STATISTICI } from "@/utils/seo";

const stations = await getOptimizedStations();
---

<BaseLayout {...SEO_STATISTICI}>
  <StatisticiApp client:load stations={stations} />
</BaseLayout>
