---
import BaseLayout from "../layouts/BaseLayout.astro";
import RadioApp from "@/components/RadioApp";
import { getOptimizedStations } from "@/utils/getOptimizedStations";
import { SEO_404 } from "@/utils/seo";

const stations = await getOptimizedStations();
---

<BaseLayout {...SEO_404}>
  <RadioApp client:load stations={stations} />
</BaseLayout>
