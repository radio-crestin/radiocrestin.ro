{
  "name": "radiocrestin.ro",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev --port 3005",
    "generate-sitemap": "node scripts/generate-sitemap.cjs",
    "generate-llms-txt": "node scripts/generate-llms-txt.cjs",
    "download-thumbnails": "node scripts/download-thumbnails.cjs",
    "build": "npm run download-thumbnails && npm run generate-sitemap && npm run generate-llms-txt && astro build && npm run upload-sourcemaps",
    "upload-sourcemaps": "POSTHOG_CLI_API_KEY=${POSTHOG_API_KEY} POSTHOG_CLI_PROJECT_ID=${POSTHOG_PROJECT_ID} posthog-cli --host https://eu.posthog.com sourcemap process --directory ./dist/_astro --delete-after",
    "preview": "astro preview --port 3005",
    "start": "npx serve@latest dist",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "dependencies": {
    "@astrojs/react": "^4.0.0",
    "astro": "^6.0.0",
    "hls.js": "^1.6.10",
    "posthog-js": "^1.365.5",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.4",
    "react-device-detect": "^2.2.3",
    "react-dom": "^19.2.4",
    "react-toastify": "^11.0.5",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@posthog/cli": "^0.7.5",
    "@types/node": "^24.3.0",
    "@types/qrcode.react": "^1.0.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9",
    "prettier": "^3.6.2",
    "sass": "^1.87.0",
    "sharp": "^0.34.5",
    "typescript": "^5",
    "vitest": "^4.1.4",
    "wrangler": "^4.0.0"
  }
}
